<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="ExamReady.Views.ExamGeneratorView">
    <DockPanel Margin="10">
        <!-- Config Panel -->
        <Border DockPanel.Dock="Top" Background="#2B2B2B" Padding="15" Margin="0,0,0,10">
            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="120,250,120,*">
                <!-- Subject -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Subject:" VerticalAlignment="Center"/>
                <ComboBox x:Name="CmbSubject" Grid.Row="0" Grid.Column="1" Margin="0,0,20,0"/>
                
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Total Marks:" VerticalAlignment="Center"/>
                <NumericUpDown x:Name="NumTotalMarks" Grid.Row="0" Grid.Column="3" Minimum="1" Maximum="500" Value="50"/>

                <!-- Difficulty Distribution -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Easy %:" VerticalAlignment="Center" Margin="0,10,0,0"/>
                <NumericUpDown x:Name="NumEasy" Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="100" Value="30" Margin="0,10,20,0"/>
                
                <TextBlock Grid.Row="1" Grid.Column="2" Text="Medium %:" VerticalAlignment="Center" Margin="0,10,0,0"/>
                <NumericUpDown x:Name="NumMedium" Grid.Row="1" Grid.Column="3" Minimum="0" Maximum="100" Value="40" Margin="0,10,0,0"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Hard %:" VerticalAlignment="Center" Margin="0,10,0,0"/>
                <NumericUpDown x:Name="NumHard" Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="100" Value="30" Margin="0,10,20,0"/>

                <Button x:Name="BtnGenerate" Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" 
                        Content="Generate Exam" Click="OnGenerateClick" 
                        HorizontalAlignment="Left" Margin="0,10,0,0"
                        Background="#4CAF50" Foreground="White" Padding="20,8"/>
            </Grid>
        </Border>

        <!-- Preview Grid -->
        <Border DockPanel.Dock="Top" Margin="0,0,0,10">
            <DataGrid x:Name="PreviewGrid" 
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Height="280">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Q#" Binding="{Binding QuestionNumber}" Width="40"/>
                    <DataGridTextColumn Header="Question" Binding="{Binding QuestionText}" Width="*"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding QType}" Width="80"/>
                    <DataGridTextColumn Header="Difficulty" Binding="{Binding Difficulty}" Width="80"/>
                    <DataGridTextColumn Header="Marks" Binding="{Binding Marks}" Width="60"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Actions Panel -->
        <Border Background="#262626" Padding="15">
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Total Marks: " VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock x:Name="TxtSelectedMarks" Text="0" VerticalAlignment="Center" FontWeight="Bold" FontSize="16"/>
                    <TextBlock x:Name="TxtQuestionCount" Text="" VerticalAlignment="Center" Margin="20,0,0,0"/>
                </StackPanel>
                
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnPrint" Content="Print" Click="OnPrintClick" IsEnabled="False" Margin="0,0,10,0"/>
                    <Button x:Name="BtnExport" Content="Export PDF" Click="OnExportPdfClick" IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>
    </DockPanel>
</UserControl>
