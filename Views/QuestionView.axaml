<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="ExamReady.Views.QuestionView">
    <DockPanel Margin="10">
        <!-- Filter Panel -->
        <Border DockPanel.Dock="Top" Background="#2B2B2B" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Filter by Subject:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="FilterSubject" Width="200" Margin="0,0,10,0" SelectionChanged="OnFilterChanged"/>
                <Button Content="Show All" Click="OnShowAllClick" Padding="10,5"/>
                <Button Content="Refresh" Click="OnRefreshClick" Padding="10,5"/>
            </StackPanel>
        </Border>

        <!-- Data Grid -->
        <Border DockPanel.Dock="Top" Margin="0,0,0,10">
            <DataGrid x:Name="QuestionsGrid" 
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      Height="250"
                      SelectionChanged="OnGridSelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="50"/>
                    <DataGridTextColumn Header="Subject" Binding="{Binding Subject}" Width="100"/>
                    <DataGridTextColumn Header="Question" Binding="{Binding QuestionText}" Width="*"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding QType}" Width="80"/>
                    <DataGridTextColumn Header="Difficulty" Binding="{Binding Difficulty}" Width="80"/>
                    <DataGridTextColumn Header="Marks" Binding="{Binding Marks}" Width="60"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Input Panel -->
        <Border Background="#262626" Padding="15">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="100,*,100,*">
                <!-- Row 1 -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Subject:" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtSubject" Grid.Row="0" Grid.Column="1" Watermark="Enter subject name"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Question:" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtQuestionText" Grid.Row="0" Grid.Column="3" Watermark="Enter question text" 
                         AcceptsReturn="True" TextWrapping="Wrap" Height="60"/>

                <!-- Row 2 -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Type:" VerticalAlignment="Center" Margin="0,10,0,0"/>
                <ComboBox x:Name="CmbQType" Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" SelectionChanged="OnQTypeChanged">
                    <ComboBoxItem Content="MCQ"/>
                    <ComboBoxItem Content="Descriptive"/>
                </ComboBox>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="Difficulty:" VerticalAlignment="Center" Margin="0,10,0,0"/>
                <ComboBox x:Name="CmbDifficulty" Grid.Row="1" Grid.Column="3" Margin="0,10,0,0">
                    <ComboBoxItem Content="Easy"/>
                    <ComboBoxItem Content="Medium"/>
                    <ComboBoxItem Content="Hard"/>
                </ComboBox>

                <!-- Row 3 -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Marks:" VerticalAlignment="Center" Margin="0,10,0,0"/>
                <NumericUpDown x:Name="NumMarks" Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" 
                               Minimum="1" Maximum="100" Value="1"/>

                <!-- MCQ Options (hidden by default) -->
                <Border x:Name="MCQPanel" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" 
                    IsVisible="False" Background="#1F1F1F" Padding="10" Margin="0,15,0,0">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="80,*,80,*">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Option A:"/>
                        <TextBox x:Name="TxtOptionA" Grid.Row="0" Grid.Column="1"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Option B:"/>
                        <TextBox x:Name="TxtOptionB" Grid.Row="0" Grid.Column="3"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Option C:" Margin="0,5,0,0"/>
                        <TextBox x:Name="TxtOptionC" Grid.Row="1" Grid.Column="1" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Option D:" Margin="0,5,0,0"/>
                        <TextBox x:Name="TxtOptionD" Grid.Row="1" Grid.Column="3" Margin="0,5,0,0"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Answer:" Margin="0,5,0,0"/>
                        <ComboBox x:Name="CmbCorrectAnswer" Grid.Row="2" Grid.Column="1" Margin="0,5,0,0" Width="100" HorizontalAlignment="Left">
                            <ComboBoxItem Content="A"/>
                            <ComboBoxItem Content="B"/>
                            <ComboBoxItem Content="C"/>
                            <ComboBoxItem Content="D"/>
                        </ComboBox>
                    </Grid>
                </Border>

                <!-- Buttons -->
                <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="4" 
                            Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,20,0,0">
                    <Button Content="Add" Click="OnAddClick" Background="#4CAF50" Foreground="White"/>
                    <Button Content="Update" Click="OnUpdateClick" Background="#2196F3" Foreground="White"/>
                    <Button Content="Delete" Click="OnDeleteClick" Background="#F44336" Foreground="White"/>
                    <Button Content="Clear" Click="OnClearClick"/>
                </StackPanel>
            </Grid>
        </Border>
    </DockPanel>
</UserControl>
